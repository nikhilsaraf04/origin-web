# Origin Web — environment variables
# Copy this to .env.local and fill in real values. .env.local is gitignored.

# Required: Anthropic API key, used server-side only by /api/scan.
# Get one from https://console.anthropic.com/
# NEVER expose this client-side.
ANTHROPIC_API_KEY=

# Supabase project — used for cross-device sync of coffee logs.
# Both vars must be the PUBLISHABLE / ANON values (never service-role).
# RLS protects per-user data; these are safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://tohgsibktcteoghayndt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_cEG7UsgQD2-9lYOJVUkQPQ_EL4Mggey
